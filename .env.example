# ---- Copy this file to .env and fill in real values. Never commit .env. ----

# ---- Agent brain auth: pick ONE of the two options below ----
#
# Option A (subscription): leave BOTH lines below blank/unset and instead log in once with
#   your Claude plan:  npm i -g @anthropic-ai/claude-code  &&  claude   (then type /login)
#   The SDK reuses that login automatically. Best for local runs.
#
# Option B (pay-as-you-go): set an API key from https://platform.claude.com
ANTHROPIC_API_KEY=
#
# For Docker/headless subscription auth, generate a token with `claude setup-token`
# and put it here instead of logging in interactively:
# CLAUDE_CODE_OAUTH_TOKEN=

# GitHub token the agency ACTS as. Use the BOT account's fine-grained token so comments,
# PRs, and labels are attributed to the bot (not you).
# Permissions: Contents, Issues, Pull requests, Workflows = Read & write; Metadata = Read.
GITHUB_TOKEN=github_pat_...

# Optional: your OWNER token (the account that owns the repos). Used ONLY to auto-invite the
# bot as a collaborator on watched repos — the bot can't invite itself. Without this you must
# invite the bot manually. Needs admin on the target repos (a classic token with `repo`, or a
# fine-grained token with Administration: read & write).
# ADMIN_GITHUB_TOKEN=github_pat_...

# The GitHub account/org the agency works under
GITHUB_OWNER=ArneNostitz

# Repos to watch. Preferred: list them in config/repos.txt (one per line).
# You can also set them here as a comma-separated list (or a single TARGET_REPO).
# TARGET_REPOS=sandbox-project,another-repo
TARGET_REPO=sandbox-project

# How an issue starts the agency:
#   mention (default) -> the issue mentions a handle from config/team.txt, e.g. "@dev ..."
#   label             -> the issue carries QUEUE_LABEL
#   any               -> every new issue (aggressive)
TRIGGER_MODE=mention
# Optional: extra handles on top of config/team.txt (comma-separated), e.g. @dev,@agency
# HANDLES=@dev
QUEUE_LABEL=agency:queue
# Add this label to an issue to make the agency skip it.
IGNORE_LABEL=agency:ignore

# Run mode: once | watch | webhook
#   watch   -> poll every POLL_INTERVAL_SECONDS (simple, default in Docker)
#   webhook -> react instantly to GitHub webhooks (needs a public URL; see COOLIFY.md)
RUN_MODE=watch
POLL_INTERVAL_SECONDS=60

# Webhook mode only (event-driven instead of polling):
# PORT=3000
# GITHUB_WEBHOOK_SECRET=choose-a-long-random-string
# PUBLIC_URL is your service's public address (Coolify domain). With PUBLIC_URL + the secret
# set, webhook mode auto-registers the GitHub webhooks on every watched repo — no manual setup.
# PUBLIC_URL=https://agency.example.com

# Password-protect the status dashboard (HTTP Basic Auth). Any username, this password.
# Leave unset to leave the dashboard open. /webhook and /health stay open regardless.
# DASHBOARD_PASSWORD=choose-a-dashboard-password

# Per-role model overrides (defaults: planner=opus 4.8, architect/developer/reviewer=sonnet,
# tester=haiku). AGENT_MODEL overrides all roles at once.
# PLANNER_MODEL=claude-opus-4-8
# DEVELOPER_MODEL=claude-sonnet-4-6
# TESTER_MODEL=claude-haiku-4-5-20251001
# AGENT_MODEL=

# SQLite memory location (mounted volume in Docker). Defaults to ./data/agency.db locally.
# DB_PATH=/app/data/agency.db
