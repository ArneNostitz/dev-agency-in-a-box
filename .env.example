# ---- Copy this file to .env and fill in real values. Never commit .env. ----
# Only bootstrap + auth + execution-identity vars live here now. Everything operational
# (trigger, labels, concurrency, budgets, gitnexus, models, preview, session budget, …) is
# managed in the dashboard → Settings / Operations and stored in the DB.

# ── Bootstrap / infra ──────────────────────────────────────────────────────
# Run mode: watch (poll) | webhook (event-driven, needs a public URL) | once
RUN_MODE=watch
# "development" on staging shows a DEV badge in the UI; default is production.
# APP_ENV=development
# Webhook mode only:
# GITHUB_WEBHOOK_SECRET=choose-a-long-random-string
# On redeploy, finish in-flight runs before exiting (ms). Pairs with stop_grace_period.
# GRACEFUL_SHUTDOWN_MS=570000
# SQLite memory location (mounted volume in Docker; ./data/agency.db locally).
# DB_PATH=/app/data/agency.db

# ── Auth ───────────────────────────────────────────────────────────────────
# MASTER_KEY turns on MULTI-USER mode and encrypts all stored secrets at rest.
# Generate: openssl rand -hex 32   — keep it stable (changing it makes stored secrets
# undecryptable). Unset = legacy single-user Basic Auth via DASHBOARD_PASSWORD.
# MASTER_KEY=
# First admin (multi-user). ADMIN_PASSWORD falls back to DASHBOARD_PASSWORD.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=
# ADMIN_EMAIL=
# Single-user mode dashboard password (Basic Auth). Ignored once MASTER_KEY is set.
# DASHBOARD_PASSWORD=choose-a-dashboard-password

# ── Execution identity (global for now; becomes per-user later) ─────────────
# Agent brain auth — set ONE:
#   subscription: generate with `claude setup-token` (headless/Docker)
# CLAUDE_CODE_OAUTH_TOKEN=
#   ...or pay-as-you-go API key from https://platform.claude.com
ANTHROPIC_API_KEY=

# GitHub token the agency ACTS as — use the BOT account's fine-grained token so comments,
# PRs and labels are attributed to the bot. Perms: Contents, Issues, Pull requests,
# Workflows = Read & write; Metadata = Read.
GITHUB_TOKEN=github_pat_...
# Optional OWNER token, used ONLY to auto-invite the bot as a collaborator on watched repos.
# ADMIN_GITHUB_TOKEN=github_pat_...
# The GitHub account/org the agency works under.
GITHUB_OWNER=your-github-username
# Repos to watch — preferred: config/repos.txt (one per line); or comma-separated here.
# TARGET_REPOS=sandbox-project,another-repo
