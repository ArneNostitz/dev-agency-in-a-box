# ---- Copy this file to .env and fill in real values. Never commit .env. ----

# ---- Agent brain auth: pick ONE of the two options below ----
#
# Option A (subscription): leave BOTH lines below blank/unset and instead log in once with
#   your Claude plan:  npm i -g @anthropic-ai/claude-code  &&  claude   (then type /login)
#   The SDK reuses that login automatically. Best for local runs.
#
# Option B (pay-as-you-go): set an API key from https://platform.claude.com
ANTHROPIC_API_KEY=
#
# For Docker/headless subscription auth, generate a token with `claude setup-token`
# and put it here instead of logging in interactively:
# CLAUDE_CODE_OAUTH_TOKEN=

# Fine-grained GitHub token (scoped to all your repos), used by `gh` and `git`.
# Permissions: Contents, Issues, Pull requests, Workflows = Read & write; Metadata = Read.
GITHUB_TOKEN=github_pat_...

# The GitHub account/org the agency works under
GITHUB_OWNER=ArneNostitz

# Repos to watch. Preferred: list them in config/repos.txt (one per line).
# You can also set them here as a comma-separated list (or a single TARGET_REPO).
# TARGET_REPOS=sandbox-project,another-repo
TARGET_REPO=sandbox-project

# Trigger policy:
#   REQUIRE_LABEL=false (default) -> the agency works on ANY new issue automatically.
#   REQUIRE_LABEL=true            -> it only works on issues carrying QUEUE_LABEL.
REQUIRE_LABEL=false
QUEUE_LABEL=agency:queue
# Add this label to an issue to make the agency skip it.
IGNORE_LABEL=agency:ignore

# Run mode: once | watch | webhook
#   watch   -> poll every POLL_INTERVAL_SECONDS (simple, default in Docker)
#   webhook -> react instantly to GitHub webhooks (needs a public URL; see COOLIFY.md)
RUN_MODE=watch
POLL_INTERVAL_SECONDS=60

# Webhook mode only:
# PORT=3000
# GITHUB_WEBHOOK_SECRET=choose-a-long-random-string

# Optional: pin a model (defaults to the SDK default if unset)
# AGENT_MODEL=claude-sonnet-4-6
