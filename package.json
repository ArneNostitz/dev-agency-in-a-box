{
  "name": "dev-agency",
  "version": "1.9.0",
  "description": "A self-contained, self-evolving developer agency of AI agents driven by GitHub issues.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/version.mjs && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node --env-file=.env dist/runner.js",
    "dev": "node --env-file=.env --experimental-strip-types src/runner.ts",
    "add-repo": "bash scripts/add-repo.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.160",
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.24",
    "htm": "^3.1.1",
    "jsdom": "^29.1.1",
    "preact": "^10.29.2",
    "typescript": "^5.6.0"
  }
}
